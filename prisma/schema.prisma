generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HackathonRaterType {
  PARTICIPANT
  JUDGE
  PUBLIC
}

enum MediaType {
  image
  video
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  password                 String?
  username                 String                   @unique
  avatarUrl                String?
  bio                      String?
  githubId                 String?                  @unique
  isActive                 Boolean                  @default(true)
  isVerified               Boolean                  @default(false)
  isBanned                 Boolean                  @default(false)
  role                     UserRole                 @default(USER)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  emailVerificationToken   String?                  @unique
  emailVerificationExpires DateTime?
  passwordResetToken       String?                  @unique
  passwordResetExpires     DateTime?
  projects                 Project[] // Projects authored by this user
  judgedHackathons         Hackathon[]              @relation("HackathonJudges")
  uploadedMedia            ProjectMedia[]
  likes                    Like[]
  views                    View[]
  followers                Follow[]                 @relation("Following")
  following                Follow[]                 @relation("Follower")
  subauthoredProjects      Project[]                @relation("ProjectSubauthors") // Projects where user is co-author
  socialLinks              SocialMedia[]
  Hackathon                Hackathon[]
  HackathonParticipant     HackathonParticipant[]
  HackathonProjectRating   HackathonProjectRating[]
}

model SocialMedia {
  id       String  @id @default(cuid())
  user     User    @relation(fields: [userId], references: [id])
  userId   String
  platform String // e.g. "linkedin", "github", "telegram", etc.
  url      String // Full link to the profile
  handle   String? // Optional: username on the platform
  verified Boolean @default(false) // Optional: if future verification is needed
}

model Project {
  id               String        @id @default(cuid()) // Project unique ID
  title            String // Project title
  description      String // Project description
  githubUrl        String? // GitHub repository link
  demoUrl          String? // Demo link
  previewUrl       String? // Main image preview
  status           ProjectStatus @default(DRAFT) // Project status
  privateLinkToken String?       @unique // Secret token for private access
  createdAt        DateTime      @default(now()) // Creation date
  updatedAt        DateTime      @updatedAt // Last updated date

  user   User   @relation(fields: [userId], references: [id]) // Main author
  userId String

  subauthors User[] @relation("ProjectSubauthors") // Co-authors

  hackathonProjects HackathonProject[]
  media             ProjectMedia[] // Media files
  technologies      Technology[]       @relation("ProjectTechnologies") // Used technologies
  likes             Like[] // Likes
  views             View[] // Views

  @@index([userId])
}

enum ProjectStatus {
  DRAFT // Draft
  PUBLISHED // Published
  ARCHIVED // Archived
}

enum MediaStatus {
  PENDING
  ATTACHED
}

model ProjectMedia {
  id        String      @id @default(cuid())
  type      MediaType
  url       String
  status    MediaStatus @default(PENDING)
  createdAt DateTime    @default(now())

  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([projectId])
  @@index([userId])
}

model Technology {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[] @relation("ProjectTechnologies")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id])
  userId    String
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  @@unique([userId, projectId])
  @@index([projectId])
}

model View {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  count     Int      @default(1)

  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  ipHash String?

  @@unique([projectId, userId], name: "project_user")
  @@unique([projectId, ipHash], name: "project_iphash")
  @@index([projectId])
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  follower   User   @relation("Follower", fields: [followerId], references: [id])
  followerId String

  following   User   @relation("Following", fields: [followingId], references: [id])
  followingId String

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Hackathon {
  id          String          @id @default(cuid())
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  status      HackathonStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  author                 User                      @relation(fields: [authorId], references: [id])
  authorId               String
  allowParticipantRating Boolean                   @default(true)
  allowPublicRating      Boolean                   @default(false)
  participants           HackathonParticipant[]
  themes                 HackathonThemeCategory[]  @relation("HackathonThemes")
  judges                 User[]                    @relation("HackathonJudges")
  projects               HackathonProject[]
  ratingCategories       HackathonRatingCategory[] @relation("HackathonRatingCategories")
}

enum HackathonStatus {
  OPEN
  RATING
  CLOSED
  ARCHIVED
}

model HackathonParticipant {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String

  joinedAt DateTime @default(now())

  @@unique([userId, hackathonId])
  @@index([hackathonId])
}

model HackathonThemeCategory {
  id         String      @id @default(cuid())
  name       String      @unique
  hackathons Hackathon[] @relation("HackathonThemes")
}

model HackathonProject {
  id          String    @id @default(cuid())
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  hackathonId String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String

  ratings HackathonProjectRating[]

  @@unique([hackathonId, projectId])
  @@index([hackathonId])
}

model HackathonRatingCategory {
  id                     String                   @id @default(cuid())
  name                   String
  order                  Int
  HackathonProjectRating HackathonProjectRating[]
  hackathons             Hackathon[]              @relation("HackathonRatingCategories")

  @@unique([name, order])
}

model HackathonProjectRating {
  id                 String                  @id @default(cuid())
  project            HackathonProject        @relation(fields: [hackathonProjectId], references: [id], onDelete: Cascade)
  hackathonProjectId String
  rater              User                    @relation(fields: [raterId], references: [id])
  raterType          HackathonRaterType
  raterId            String
  category           HackathonRatingCategory @relation(fields: [categoryId], references: [id])
  categoryId         String
  rating             Int

  comment   String?
  createdAt DateTime @default(now())

  @@unique([hackathonProjectId, raterId, categoryId, raterType])
  @@index([hackathonProjectId])
  @@index([categoryId])
}
